# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://lego:lego123@localhost:5432/lego_app

# ── Rebrickable (required for set sync) ───────────────────
REBRICKABLE_API_KEY=YOUR_KEY_HERE

# ── Email (Resend) ───────────────────────────────────────
# Leave blank to disable email sending in dev (no-op mode)
RESEND_API_KEY=

# ── Auth (Clerk) ─────────────────────────────────────────
# JWKS endpoint from your Clerk dashboard
CLERK_JWKS_URL=
# Set to 1 in dev to allow fake auth tokens (NEVER in production)
ALLOW_FAKE_AUTH=1
# Secret for signing sessions/tokens — generate a strong random string for prod
SECRET_KEY=change-me-in-production

# ── Affiliate Programs ──────────────────────────────────
AMAZON_AFFILIATE_TAG=bricktrack-20
# Impact.com affiliate IDs (leave blank until you sign up)
WALMART_IMPACT_AFFILIATE_ID=
TARGET_IMPACT_AFFILIATE_ID=

# ── Production checklist ─────────────────────────────────
# In production, ensure:
#   ALLOW_FAKE_AUTH=0  (or unset)
#   SECRET_KEY=<random 64+ char string>
#   DATABASE_URL=<production postgres connection>
#   RESEND_API_KEY=<your resend key>
#   CLERK_JWKS_URL=<your clerk JWKS URL>
